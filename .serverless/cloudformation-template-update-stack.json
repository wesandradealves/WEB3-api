{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "The AWS CloudFormation template for this Serverless application",
  "Resources": {
    "ServerlessDeploymentBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        }
      }
    },
    "ServerlessDeploymentBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": {
          "Ref": "ServerlessDeploymentBucket"
        },
        "PolicyDocument": {
          "Statement": [
            {
              "Action": "s3:*",
              "Effect": "Deny",
              "Principal": "*",
              "Resource": [
                {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition"
                      },
                      ":s3:::",
                      {
                        "Ref": "ServerlessDeploymentBucket"
                      },
                      "/*"
                    ]
                  ]
                },
                {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition"
                      },
                      ":s3:::",
                      {
                        "Ref": "ServerlessDeploymentBucket"
                      }
                    ]
                  ]
                }
              ],
              "Condition": {
                "Bool": {
                  "aws:SecureTransport": false
                }
              }
            }
          ]
        }
      }
    },
    "DashbooardFileProcessorLogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": "/aws/lambda/development-dashboard-file-processor"
      }
    },
    "TransferAssetsLogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": "/aws/lambda/development-dashboard-transfer-assets"
      }
    },
    "IamRoleLambdaExecution": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": [
                  "lambda.amazonaws.com"
                ]
              },
              "Action": [
                "sts:AssumeRole"
              ]
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": {
              "Fn::Join": [
                "-",
                [
                  "dourado-dashboard-service",
                  "development",
                  "lambda"
                ]
              ]
            },
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogStream",
                    "logs:CreateLogGroup",
                    "logs:TagResource"
                  ],
                  "Resource": [
                    {
                      "Fn::Sub": "arn:${AWS::Partition}:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/development-dashboard-file-processor:*"
                    },
                    {
                      "Fn::Sub": "arn:${AWS::Partition}:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/development-dashboard-transfer-assets:*"
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:PutLogEvents"
                  ],
                  "Resource": [
                    {
                      "Fn::Sub": "arn:${AWS::Partition}:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/development-dashboard-file-processor:*:*"
                    },
                    {
                      "Fn::Sub": "arn:${AWS::Partition}:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/development-dashboard-transfer-assets:*:*"
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "s3:GetObject",
                    "s3:PutObject",
                    "s3:ListBucket"
                  ],
                  "Resource": [
                    "arn:aws:s3:::development-dashboard-docs-transfer",
                    "arn:aws:s3:::development-dashboard-docs-transfer/*"
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:SendMessage",
                    "sqs:ReceiveMessage",
                    "sqs:DeleteMessage",
                    "sqs:GetQueueAttributes"
                  ],
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "DashboardTransferProcessingQueue",
                        "Arn"
                      ]
                    }
                  ]
                },
                {
                  "Effect": "Allow",
                  "Action": [
                    "sqs:ReceiveMessage",
                    "sqs:DeleteMessage",
                    "sqs:GetQueueAttributes"
                  ],
                  "Resource": [
                    {
                      "Fn::GetAtt": [
                        "DashboardTransferProcessingQueue",
                        "Arn"
                      ]
                    }
                  ]
                }
              ]
            }
          }
        ],
        "Path": "/",
        "RoleName": {
          "Fn::Join": [
            "-",
            [
              "dourado-dashboard-service",
              "development",
              {
                "Ref": "AWS::Region"
              },
              "lambdaRole"
            ]
          ]
        }
      }
    },
    "DashbooardFileProcessorLambdaFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Code": {
          "S3Bucket": {
            "Ref": "ServerlessDeploymentBucket"
          },
          "S3Key": "serverless/dourado-dashboard-service/development/1746028549177-2025-04-30T15:55:49.177Z/DashbooardFileProcessor.zip"
        },
        "Handler": "./src/functions/dashboard-file-processor/handler.handler",
        "Runtime": "nodejs18.x",
        "FunctionName": "development-dashboard-file-processor",
        "MemorySize": 512,
        "Timeout": 30,
        "Environment": {
          "Variables": {
            "ENVIRONMENT": "development",
            "HTTP_TIMEOUT": "30000",
            "DATABASE_TYPE": "postgres",
            "DATABASE_HOST": "douradodbdev.cet6pltt6ywk.us-east-2.rds.amazonaws.com",
            "DATABASE_PORT": "5432",
            "DATABASE_NAME": "dourado-dashboard",
            "DATABASE_USERNAME": "dourado_db_dev",
            "DATABASE_PASSWORD": "R4r0L4bsB4s1cdev",
            "AWS_SQS_TRANSFER_URL": "https://sqs.us-east-2.amazonaws.com/915863716341/dourado-dashboard-transfers",
            "SES_SOURCE_ARN": "arn:aws:ses:us-east-2:915863716341:identity/dourado.cash",
            "SES_EMAIL_FROM": "no-reply@dourado.cash",
            "SES_2FA_TEMPLATE": "teste-template",
            "AWS_S3_BUCKET_NAME": "development-dashboard-docs-transfers"
          }
        },
        "Role": {
          "Fn::GetAtt": [
            "IamRoleLambdaExecution",
            "Arn"
          ]
        }
      },
      "DependsOn": [
        "DashbooardFileProcessorLogGroup"
      ]
    },
    "TransferAssetsLambdaFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Code": {
          "S3Bucket": {
            "Ref": "ServerlessDeploymentBucket"
          },
          "S3Key": "serverless/dourado-dashboard-service/development/1746028549177-2025-04-30T15:55:49.177Z/TransferAssets.zip"
        },
        "Handler": "./src/functions/dashboard-transfer-assets/handler.handler",
        "Runtime": "nodejs18.x",
        "FunctionName": "development-dashboard-transfer-assets",
        "MemorySize": 512,
        "Timeout": 30,
        "Environment": {
          "Variables": {
            "ENVIRONMENT": "development",
            "HTTP_TIMEOUT": "30000",
            "DATABASE_TYPE": "postgres",
            "DATABASE_HOST": "douradodbdev.cet6pltt6ywk.us-east-2.rds.amazonaws.com",
            "DATABASE_PORT": "5432",
            "DATABASE_NAME": "dourado-dashboard",
            "DATABASE_USERNAME": "dourado_db_dev",
            "DATABASE_PASSWORD": "R4r0L4bsB4s1cdev",
            "AWS_SQS_TRANSFER_URL": "https://sqs.us-east-2.amazonaws.com/915863716341/dourado-dashboard-transfers",
            "AWS_COGNITO_CLIENT_ID": "41m2n49de1n1e4nqavkll143g4",
            "AWS_COGNITO_CLIENT_ID_SECRET": "lq2dd3k14ni8329r65bnae56mk06t74p854ujudmmjnjlkk5dg7",
            "BLOCKCHAIN_API_URL": "https://api.blockcypher.com/v1/btc/main",
            "BLOCKCHAIN_API_KEY_HASH": "0f1c2b8a3d4e4f5a8b7e9c6d3f4e5a6b",
            "BDM_API_KEY": "",
            "BASE_URL_BDM": "https://opiihi8ab4.execute-api.us-east-2.amazonaws.com",
            "BDM_VERSION": "v26",
            "BDM_AUTH_USERNAME": "elnora8277@uorak.com",
            "BDM_AUTH_PASSWORD": "Dourado.24"
          }
        },
        "Role": {
          "Fn::GetAtt": [
            "IamRoleLambdaExecution",
            "Arn"
          ]
        }
      },
      "DependsOn": [
        "TransferAssetsLogGroup"
      ]
    },
    "DashbooardFileProcessorLambdaVersionkOYH7eDvFicUqADp7xQSTBZHgEa4w531hWbgKeY40": {
      "Type": "AWS::Lambda::Version",
      "DeletionPolicy": "Retain",
      "Properties": {
        "FunctionName": {
          "Ref": "DashbooardFileProcessorLambdaFunction"
        },
        "CodeSha256": "S2p59R5Gx6U+IuQ6v4foAIOcFc2bbu1pklMkhGYfuTM="
      }
    },
    "TransferAssetsLambdaVersionkjCQPbKhUrzWyg31JodVlV4FQV8ahDgKTRhN79riM": {
      "Type": "AWS::Lambda::Version",
      "DeletionPolicy": "Retain",
      "Properties": {
        "FunctionName": {
          "Ref": "TransferAssetsLambdaFunction"
        },
        "CodeSha256": "jbsagk/exbZr6eshZcC/5OZT0p/zT/qJstW9W6+w1Uw="
      }
    },
    "S3BucketDevelopmentdashboarddocstransfer": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "development-dashboard-docs-transfer",
        "NotificationConfiguration": {
          "LambdaConfigurations": [
            {
              "Event": "s3:ObjectCreated:Put",
              "Function": {
                "Fn::GetAtt": [
                  "DashbooardFileProcessorLambdaFunction",
                  "Arn"
                ]
              },
              "Filter": {
                "S3Key": {
                  "Rules": [
                    {
                      "Name": "suffix",
                      "Value": ".csv"
                    }
                  ]
                }
              }
            }
          ]
        }
      },
      "DependsOn": [
        "DashbooardFileProcessorLambdaPermissionDevelopmentdashboarddocstransferS3"
      ]
    },
    "DashbooardFileProcessorLambdaPermissionDevelopmentdashboarddocstransferS3": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
          "Fn::GetAtt": [
            "DashbooardFileProcessorLambdaFunction",
            "Arn"
          ]
        },
        "Action": "lambda:InvokeFunction",
        "Principal": "s3.amazonaws.com",
        "SourceArn": {
          "Fn::Join": [
            "",
            [
              "arn:",
              {
                "Ref": "AWS::Partition"
              },
              ":s3:::development-dashboard-docs-transfer"
            ]
          ]
        },
        "SourceAccount": {
          "Ref": "AWS::AccountId"
        }
      }
    },
    "TransferAssetsEventSourceMappingSQSDashboardTransferProcessingQueue": {
      "Type": "AWS::Lambda::EventSourceMapping",
      "DependsOn": [
        "IamRoleLambdaExecution"
      ],
      "Properties": {
        "BatchSize": 1,
        "EventSourceArn": {
          "Fn::GetAtt": [
            "DashboardTransferProcessingQueue",
            "Arn"
          ]
        },
        "FunctionName": {
          "Fn::GetAtt": [
            "TransferAssetsLambdaFunction",
            "Arn"
          ]
        },
        "Enabled": true
      }
    },
    "DashboardTransferProcessingQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "development-dashboard-docs-transfer.fifo",
        "FifoQueue": true,
        "VisibilityTimeout": 30,
        "ContentBasedDeduplication": true
      }
    }
  },
  "Outputs": {
    "ServerlessDeploymentBucketName": {
      "Value": {
        "Ref": "ServerlessDeploymentBucket"
      },
      "Export": {
        "Name": "sls-dourado-dashboard-service-development-ServerlessDeploymentBucketName"
      }
    },
    "DashbooardFileProcessorLambdaFunctionQualifiedArn": {
      "Description": "Current Lambda function version",
      "Value": {
        "Ref": "DashbooardFileProcessorLambdaVersionkOYH7eDvFicUqADp7xQSTBZHgEa4w531hWbgKeY40"
      },
      "Export": {
        "Name": "sls-dourado-dashboard-service-development-DashbooardFileProcessorLambdaFunctionQualifiedArn"
      }
    },
    "TransferAssetsLambdaFunctionQualifiedArn": {
      "Description": "Current Lambda function version",
      "Value": {
        "Ref": "TransferAssetsLambdaVersionkjCQPbKhUrzWyg31JodVlV4FQV8ahDgKTRhN79riM"
      },
      "Export": {
        "Name": "sls-dourado-dashboard-service-development-TransferAssetsLambdaFunctionQualifiedArn"
      }
    }
  }
}