{
	"name": "dourado-pos-api",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"typeorm": "yarn build && ts-node ./node_modules/typeorm/cli.js -d ./src/infrastructure/database/config/postgres.provider.ts",
		"db:create": "ts-node ./node_modules/typeorm-extension/bin/cli.cjs --initialDatabase postgres db:create -d ./src/infrastructure/database/config/postgres.provider.ts",
		"migration:revert": "yarn typeorm migration:revert",
		"migration:cache": "yarn typeorm cache:clear",
		"migration:gen": "yarn typeorm migration:generate",
		"migration:run": "yarn typeorm migration:run",
		"migration:show": "yarn typeorm migration:show"
	},
	"dependencies": {
		"@aws-sdk/client-cognito-identity-provider": "^3.760.0",
		"@aws-sdk/client-s3": "^3.758.0",
		"@aws-sdk/client-ses": "^3.577.0",
		"@nestjs/common": "^10.3.8",
		"@nestjs/config": "^3.2.2",
		"@nestjs/core": "^10.0.0",
		"@nestjs/jwt": "^10.2.0",
		"@nestjs/passport": "^10.0.3",
		"@nestjs/platform-express": "^11.0.12",
		"@nestjs/swagger": "^11.0.6",
		"@nestjs/typeorm": "^10.0.2",
		"axios": "^1.7.1",
		"bcrypt": "^5.1.1",
		"class-transform": "^0.7.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"csv-parser": "^3.2.0",
		"date-fns": "^4.1.0",
		"dotenv": "^16.4.5",
		"install": "^0.13.0",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"passport-local": "^1.0.0",
		"pg": "^8.11.5",
		"reflect-metadata": "^0.1.13",
		"rxjs": "^7.8.1",
		"serverless": "3.32.0",
		"serverless-localstack": "^1.3.1",
		"serverless-offline": "^14.4.0",
		"serverless-offline-sqs": "^8.0.0",
		"serverless-webpack": "^5.15.1",
		"swagger-ui-express": "^5.0.1",
		"typeorm": "^0.3.20",
		"yarn": "^1.22.22"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.0.0",
		"@nestjs/schematics": "^10.0.0",
		"@nestjs/testing": "^10.0.0",
		"@types/express": "^5.0.1",
		"@types/jest": "^29.5.2",
		"@types/multer": "^1.4.12",
		"@types/node": "^20.3.1",
		"@types/passport-jwt": "^4.0.1",
		"@types/passport-local": "^1.0.38",
		"@types/supertest": "^2.0.12",
		"@typescript-eslint/eslint-plugin": "^6.0.0",
		"@typescript-eslint/parser": "^6.0.0",
		"eslint": "^8.42.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-prettier": "^5.0.0",
		"jest": "^29.5.0",
		"prettier": "^3.0.0",
		"source-map-support": "^0.5.21",
		"supertest": "^6.3.3",
		"ts-jest": "^29.1.0",
		"ts-loader": "^9.4.3",
		"ts-node": "^10.9.1",
		"tsconfig-paths": "^4.2.0",
		"typeorm-extension": "^3.5.1",
		"typescript": "^5.1.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
